{
  "manifest_version": 3,
  "name": "OfferFlow — Save Job",
  "version": "0.1.0",
  "description": "Save job postings from LinkedIn, Greenhouse, Lever, Ashby, Workday and Indeed straight into OfferFlow.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Save to OfferFlow",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://boards.greenhouse.io/*",
        "*://job-boards.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://jobs.ashbyhq.com/*",
        "*://*.myworkdayjobs.com/*",
        "*://*.indeed.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
