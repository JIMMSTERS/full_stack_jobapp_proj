# Copy this file to .env and fill in real values.

# Database. For local dev without Postgres, use SQLite:
#   DATABASE_URL=sqlite:///./offerflow.db
DATABASE_URL=postgresql+psycopg://offerflow:offerflow@localhost:5432/offerflow

# Google OAuth credentials (Google Cloud Console -> APIs & Services -> Credentials).
# Authorized redirect URI must be: http://127.0.0.1:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret used to sign the OAuth state cookie. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Where to send the user after a successful login (the React dev server).
FRONTEND_URL=http://localhost:5173

# Browser origins allowed to call this API (comma-separated). In production set
# this to your deployed frontend URL, e.g. https://offerflow.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cookie flags for the session cookie. Locally leave these as-is. In production,
# when the frontend and API are on different domains, set:
#   COOKIE_SAMESITE=none
#   COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Enables the public "Try the demo" login (throwaway sandbox account seeded with
# sample data, no Google sign-in). Set to false to disable.
DEMO_MODE_ENABLED=true

# LLM email classifier (Anthropic). When enabled AND a key is set, the Gmail
# classifier uses an LLM for structured extraction, falling back to the keyword
# heuristic on any error. Left off by default (zero external calls / cost).
LLM_CLASSIFIER_ENABLED=false
ANTHROPIC_API_KEY=
LLM_MODEL=claude-3-5-haiku-latest
LLM_TIMEOUT_SECONDS=12

